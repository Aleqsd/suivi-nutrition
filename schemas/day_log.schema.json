{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/suivi-nutrition/day_log.schema.json",
  "title": "day_log",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "date",
    "timezone",
    "source"
  ],
  "properties": {
    "date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "timezone": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "$ref": "#/$defs/source"
    },
    "sleep": {
      "$ref": "#/$defs/sleep"
    },
    "meals": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/meal_entry"
      }
    },
    "hydration": {
      "$ref": "#/$defs/hydration"
    },
    "activity": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/activity_entry"
      }
    },
    "body_metrics": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/body_metric"
      }
    },
    "supplements": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/supplement_intake"
      }
    },
    "symptoms": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/symptom"
      }
    },
    "digestion": {
      "$ref": "#/$defs/digestion"
    },
    "health_events": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/health_event"
      }
    },
    "lab_results": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/lab_result"
      }
    },
    "notes": {
      "type": "string"
    }
  },
  "$defs": {
    "time": {
      "type": "string",
      "pattern": "^([01]\\d|2[0-3]):[0-5]\\d$"
    },
    "datetime": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}T([01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d)?([+-]([01]\\d|2[0-3]):[0-5]\\d|Z)?$"
    },
    "date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "origin"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "manual",
            "import"
          ]
        },
        "origin": {
          "type": "string"
        },
        "record_id": {
          "type": "string"
        },
        "imported_at": {
          "type": "string"
        }
      }
    },
    "sleep": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "start": {
          "$ref": "#/$defs/time"
        },
        "end": {
          "$ref": "#/$defs/time"
        },
        "duration_h": {
          "type": "number",
          "minimum": 0
        },
        "quality": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "hydration": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "total_ml": {
          "type": "number",
          "minimum": 0
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "activity_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "type": "string"
        },
        "start": {
          "$ref": "#/$defs/time"
        },
        "duration_min": {
          "type": "integer",
          "minimum": 0
        },
        "intensity": {
          "type": "string",
          "enum": [
            "low",
            "moderate",
            "high"
          ]
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "estimated_nutrition": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "energy_kcal": {
          "type": "number",
          "minimum": 0
        },
        "protein_g": {
          "type": "number",
          "minimum": 0
        },
        "carbs_g": {
          "type": "number",
          "minimum": 0
        },
        "fat_g": {
          "type": "number",
          "minimum": 0
        },
        "fiber_g": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "meal_assessment": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "estimated_energy_kcal": {
          "type": "number",
          "minimum": 0
        },
        "quality_score": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "estimation_confidence": {
          "type": "string",
          "enum": [
            "high",
            "medium",
            "low"
          ]
        },
        "recommendations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "meal_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label"
      ],
      "anyOf": [
        {
          "required": [
            "quantity",
            "unit"
          ]
        },
        {
          "required": [
            "portion_text"
          ]
        }
      ],
      "properties": {
        "food_key": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "brand": {
          "type": "string"
        },
        "quantity": {
          "type": "number",
          "minimum": 0
        },
        "unit": {
          "type": "string",
          "enum": [
            "g",
            "kg",
            "ml",
            "l",
            "unit",
            "piece",
            "slice",
            "plate",
            "bowl",
            "cup",
            "glass",
            "pack",
            "tbsp",
            "tsp"
          ]
        },
        "portion_text": {
          "type": "string"
        },
        "quantity_source": {
          "type": "string",
          "enum": [
            "exact",
            "estimated",
            "unknown"
          ]
        },
        "preparation": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        },
        "estimated_nutrition": {
          "$ref": "#/$defs/estimated_nutrition"
        }
      }
    },
    "meal_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "time",
        "meal_type",
        "items"
      ],
      "properties": {
        "time": {
          "$ref": "#/$defs/time"
        },
        "logged_at": {
          "$ref": "#/$defs/datetime"
        },
        "meal_type": {
          "type": "string",
          "enum": [
            "breakfast",
            "lunch",
            "dinner",
            "snack"
          ]
        },
        "capture_method": {
          "type": "string",
          "enum": [
            "realtime",
            "same_day_recall",
            "historical_recall",
            "import",
            "photo_share"
          ]
        },
        "confidence": {
          "type": "string",
          "enum": [
            "high",
            "medium",
            "low"
          ]
        },
        "location": {
          "type": "string"
        },
        "context": {
          "type": "string"
        },
        "source_text": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        },
        "meal_assessment": {
          "$ref": "#/$defs/meal_assessment"
        },
        "items": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/meal_item"
          }
        }
      }
    },
    "body_metric": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "value",
        "unit"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "height",
            "weight",
            "waist_circumference",
            "body_fat_pct",
            "heart_rate",
            "temperature",
            "blood_pressure_systolic",
            "blood_pressure_diastolic"
          ]
        },
        "time": {
          "$ref": "#/$defs/time"
        },
        "value": {
          "type": "number"
        },
        "unit": {
          "type": "string",
          "enum": [
            "kg",
            "cm",
            "percent",
            "bpm",
            "celsius",
            "mmHg"
          ]
        },
        "source": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "supplement_intake": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "dose",
        "unit"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "dose": {
          "type": "number",
          "minimum": 0
        },
        "unit": {
          "type": "string",
          "enum": [
            "mg",
            "g",
            "mcg",
            "IU",
            "capsule",
            "tablet",
            "drop"
          ]
        },
        "time": {
          "$ref": "#/$defs/time"
        },
        "frequency": {
          "type": "string",
          "enum": [
            "once",
            "daily",
            "weekly",
            "as_needed"
          ]
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "symptom": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "severity"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "severity": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5
        },
        "time": {
          "$ref": "#/$defs/time"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "digestion": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "bowel_movements": {
          "type": "integer",
          "minimum": 0
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "health_event": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "label",
        "status"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "diagnosis",
            "symptom",
            "appointment",
            "illness",
            "treatment",
            "injury",
            "note"
          ]
        },
        "label": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "planned",
            "active",
            "resolved",
            "cancelled"
          ]
        },
        "start_date": {
          "$ref": "#/$defs/date"
        },
        "end_date": {
          "$ref": "#/$defs/date"
        },
        "practitioner": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "lab_result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "test_code",
        "label",
        "collected_at",
        "value",
        "unit"
      ],
      "properties": {
        "test_code": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "collected_at": {
          "$ref": "#/$defs/date"
        },
        "value": {
          "type": [
            "number",
            "string"
          ]
        },
        "unit": {
          "type": "string"
        },
        "reference_low": {
          "type": "number"
        },
        "reference_high": {
          "type": "number"
        },
        "laboratory": {
          "type": "string"
        },
        "source": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}
