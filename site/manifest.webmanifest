{
  "id": "/app/",
  "name": "Atlas",
  "short_name": "Atlas",
  "description": "Journal santé et nutrition personnel avec capture photo de repas.",
  "lang": "fr-FR",
  "start_url": "/app/?source=pwa",
  "scope": "/",
  "display": "standalone",
  "background_color": "#f6f1e5",
  "theme_color": "#234b44",
  "icons": [
    {
      "src": "/icon.svg",
      "sizes": "any",
      "type": "image/svg+xml",
      "purpose": "any maskable"
    }
  ],
  "share_target": {
    "action": "/app/share-target/",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "files": [
        {
          "name": "photo",
          "accept": [
            "image/*"
          ]
        }
      ]
    }
  }
}
