/*
  X-Robots-Tag: noindex, nofollow, noarchive
  Referrer-Policy: no-referrer
  Content-Security-Policy: default-src 'self'; script-src 'self' https://identity.netlify.com; connect-src 'self' https://identity.netlify.com https:; style-src 'self' 'unsafe-inline'; font-src 'self'; img-src 'self' data: blob:; object-src 'none'; base-uri 'self'; form-action 'self' https://identity.netlify.com; frame-src https://identity.netlify.com https://accounts.google.com; frame-ancestors 'none'; upgrade-insecure-requests
  X-Frame-Options: DENY
  Permissions-Policy: accelerometer=(), autoplay=(), camera=(), geolocation=(), gyroscope=(), microphone=(), payment=(), usb=()

/
  Cache-Control: private, no-store, max-age=0

/index.html
  Cache-Control: private, no-store, max-age=0

/app
  Cache-Control: private, no-store, max-age=0

/app/
  Cache-Control: private, no-store, max-age=0

/app/index.html
  Cache-Control: private, no-store, max-age=0

/app.js
  Cache-Control: private, no-store, max-age=0

/styles.css
  Cache-Control: private, no-store, max-age=0

/fonts.css
  Cache-Control: public, max-age=31536000, immutable

/fonts/*
  Cache-Control: public, max-age=31536000, immutable

/auth.js
  Cache-Control: private, no-store, max-age=0

/capture.js
  Cache-Control: private, no-store, max-age=0

/pwa.js
  Cache-Control: private, no-store, max-age=0

/sw.js
  Cache-Control: private, no-store, max-age=0

/manifest.webmanifest
  Cache-Control: private, no-store, max-age=0

/app/data/*
  Cache-Control: private, no-store, max-age=0
